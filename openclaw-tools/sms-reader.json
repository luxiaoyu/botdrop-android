{
  "$schema": "https://openclaw.dev/schemas/tool-v1.json",
  "name": "sms-reader",
  "version": "1.0.0",
  "description": "Read SMS messages from the Android device running BotDrop",
  
  "config": {
    "type": "exec",
    "command": "botdrop-sms",
    "timeout": 15000
  },
  
  "parameters": {
    "action": {
      "type": "string",
      "required": true,
      "enum": ["latest", "recent", "unread", "check"],
      "description": "The action to perform when reading SMS"
    },
    "limit": {
      "type": "integer",
      "required": false,
      "minimum": 1,
      "maximum": 50,
      "default": 5,
      "description": "Number of messages to retrieve (only for 'recent' action)"
    }
  },
  
  "actions": {
    "latest": {
      "description": "Get the most recent SMS message",
      "params": {},
      "returns": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "sender": { "type": "string", "description": "Phone number or sender ID" },
          "body": { "type": "string", "description": "SMS message content" },
          "timestamp": { "type": "integer" },
          "date": { "type": "string", "format": "date-time" },
          "read": { "type": "boolean" },
          "type": { "type": "string", "enum": ["inbox", "sent", "draft", "outbox"] }
        }
      }
    },
    "recent": {
      "description": "Get recent SMS messages",
      "params": {
        "limit": { "type": "integer", "default": 5 }
      },
      "returns": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "sender": { "type": "string" },
                "body": { "type": "string" },
                "timestamp": { "type": "integer" },
                "date": { "type": "string" },
                "read": { "type": "boolean" },
                "type": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "unread": {
      "description": "Get all unread SMS messages",
      "params": {},
      "returns": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "messages": { "type": "array" }
        }
      }
    },
    "check": {
      "description": "Check if SMS permission is granted",
      "params": {},
      "returns": {
        "type": "object",
        "properties": {
          "has_permission": { "type": "boolean" },
          "permission": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  },
  
  "systemPrompt": {
    "context": "You have access to the device's SMS messages through the sms-reader tool. Use this when the user asks about their text messages, verification codes, or any SMS-related queries.",
    "guidelines": [
      "Always ask for confirmation before reading SMS if the request seems sensitive",
      "Summarize SMS content clearly, highlighting important information like verification codes",
      "Respect user privacy - don't read SMS unless explicitly requested",
      "If SMS permission is not granted, guide the user to enable it in BotDrop app settings"
    ],
    "examples": [
      {
        "user": "What was my last text message?",
        "assistant": "Let me check your latest SMS...",
        "toolCall": { "action": "latest" }
      },
      {
        "user": "Any new messages?",
        "assistant": "I'll check for unread messages.",
        "toolCall": { "action": "unread" }
      },
      {
        "user": "Did I get the verification code?",
        "assistant": "Let me look at your recent messages for a verification code.",
        "toolCall": { "action": "recent", "limit": 3 }
      }
    ]
  }
}
